# Backend environment configuration for AuraPort Portfolio Builder
# Copy this file to .env and update the values before deployment.

PORT=3000
NODE_ENV=production
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=2h
CORS_ORIGIN=http://localhost:3000

# Optional resume AI parser integration
GEMINI_API_KEY=

# Optional email notification settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=you@example.com
EMAIL_PASS=your-email-password
RECEIVER_EMAIL=you@example.com
